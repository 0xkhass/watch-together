{
  "name": "watch-together",
  "version": "1.0.0",
  "private": true,
  "description": "Watch videos together in real-time with friends",
  "workspaces": [
    "packages/server",
    "packages/client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=packages/server -- --host 0.0.0.0",
    "dev:client": "npm run dev --workspace=packages/client -- --host 0.0.0.0",
    "build": "npm run build --workspace=packages/server && npm run build --workspace=packages/client",
    "start": "npm run start --workspace=packages/server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}