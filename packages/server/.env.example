PORT=3001
# Comma-separated. On Render, set to your Vercel URL — no trailing slash.
CLIENT_URL=http://localhost:5173
# CLIENT_URL=https://watch-together-client-nu.vercel.app,http://localhost:5173
# Wrong: https://watch-together-client-nu.vercel.app/  (trailing slash breaks CORS)
NODE_ENV=development

# Supabase → Project Settings → Database → Connection string (URI, port 6543 pooler)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Production only: public URL of this API (no trailing slash)
# PUBLIC_URL=https://your-api.onrender.com

# Optional
# MAX_VIDEO_UPLOAD_MB=200
